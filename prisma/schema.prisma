generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Color {
  AZUL
  VERDE
  ROSA
  MORADO
}

enum StockChangeType {
  SALE
  MANUAL_ADD
  MANUAL_REMOVE
  ADJUSTMENT
  INITIAL
}

enum MLListingStatus {
  ACTIVE
  PAUSED
  CLOSED
  UNDER_REVIEW
}

enum UserRole {
  ADMIN
  PARTNER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(PARTNER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  stockLogs    StockLog[]
  stockEntries StockEntry[]
  apiKeys      ApiKey[]
  withdrawals  Withdrawal[]
  expenses     Expense[]
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  userId     String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([key])
}

model MLCredential {
  id             String   @id @default(cuid())
  appId          String
  clientSecret   String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  mlUserId       BigInt
  scope          String   @default("offline_access read write")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tokenExpiresAt])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  contact   String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products     Product[]
  stockEntries StockEntry[]
  expenses     Expense[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  supplierCode String
  unitCost     Decimal  @db.Decimal(10, 2)
  supplierId   String
  brand        String?
  description  String?
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier              Supplier               @relation(fields: [supplierId], references: [id])
  variants              ProductVariant[]
  withdrawalAllocations WithdrawalAllocation[]
  groupItems            ProductGroupItem[]
  expenses              Expense[]

  @@unique([supplierId, supplierCode])
  @@index([supplierCode])
  @@index([brand])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  color        Color?
  variantLabel String?
  stock        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  packItems       PackItem[]
  stockLogs       StockLog[]
  stockEntryItems StockEntryItem[]

  @@unique([productId, color])
  @@index([stock])
  @@index([productId, variantLabel])
}

model Pack {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  salePrice   Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockSyncEnabled      Boolean  @default(true)
  items                 PackItem[]
  mlListings            MLListing[]
  withdrawalAllocations WithdrawalAllocation[]
  mpTransactions        MPTransaction[]
  costs                 PackCost[]
  expenses              Expense[]

  @@index([sku])
}

model PackItem {
  id               String @id @default(cuid())
  packId           String
  productVariantId String
  quantity         Int

  pack           Pack           @relation(fields: [packId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([packId, productVariantId])
}

model MLListing {
  id           String          @id @default(cuid())
  mlItemId     String          @unique
  packId       String
  title        String?
  permalink    String?
  status       MLListingStatus @default(ACTIVE)
  currentStock Int             @default(0)
  currentPrice Decimal?        @db.Decimal(10, 2)
  lastSyncedAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  pack Pack @relation(fields: [packId], references: [id])

  @@index([packId])
}

model StockLog {
  id               String          @id @default(cuid())
  productVariantId String
  changeType       StockChangeType
  quantityChange   Int
  previousStock    Int
  newStock         Int
  reason           String?
  mlOrderId        BigInt?
  userId           String?
  createdAt        DateTime        @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  user           User?          @relation(fields: [userId], references: [id])

  @@index([productVariantId, createdAt])
  @@index([mlOrderId])
  @@index([changeType])
  @@index([createdAt])
}

model StockEntry {
  id         String   @id @default(cuid())
  supplierId String
  userId     String
  notes      String?
  totalCost  Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  supplier Supplier         @relation(fields: [supplierId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  items    StockEntryItem[]
}

model StockEntryItem {
  id               String  @id @default(cuid())
  stockEntryId     String
  productVariantId String
  quantity         Int
  unitCost         Decimal @db.Decimal(10, 2)

  stockEntry     StockEntry     @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([stockEntryId, productVariantId])
}

model WebhookLog {
  id          String    @id @default(cuid())
  topic       String
  resource    String
  mlUserId    BigInt
  payload     Json
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([topic, createdAt])
  @@index([resource])
}

model MLOrder {
  id            String    @id @default(cuid())
  mlOrderId     BigInt    @unique
  mlItemId      String
  quantity      Int
  unitPrice     Decimal   @db.Decimal(10, 2)
  totalAmount   Decimal   @db.Decimal(10, 2)
  status        String
  buyerNickname String?
  dateCreated   DateTime
  dateClosed    DateTime?
  processedAt   DateTime?
  rawPayload    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([mlItemId])
  @@index([status])
  @@index([dateCreated])
}

model Withdrawal {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(10, 2)
  date      DateTime
  concept   String
  method    String   @default("bank")
  reference String?
  notes     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                  @relation(fields: [userId], references: [id])
  allocations WithdrawalAllocation[]

  @@index([date])
}

model WithdrawalAllocation {
  id           String  @id @default(cuid())
  withdrawalId String
  packId       String?
  productId    String?
  amount       Decimal @db.Decimal(10, 2)
  notes        String?

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  pack       Pack?      @relation(fields: [packId], references: [id])
  product    Product?   @relation(fields: [productId], references: [id])

  @@index([withdrawalId])
}

model Expense {
  id              String   @id @default(cuid())
  type            String   @default("gasto")
  amount          Decimal  @db.Decimal(10, 2)
  date            DateTime
  category        String
  concept         String
  supplierId      String?
  productId       String?
  packId          String?
  productGroupId  String?
  transactionIds  String?
  notes           String?
  userId          String
  createdAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  supplier     Supplier?     @relation(fields: [supplierId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  pack         Pack?         @relation(fields: [packId], references: [id])
  productGroup ProductGroup? @relation(fields: [productGroupId], references: [id])

  @@index([date])
  @@index([category])
}

model MPTransaction {
  id            String   @id @default(cuid())
  mpId          BigInt   @unique
  type          String
  amount        Decimal  @db.Decimal(10, 2)
  balanceChange Decimal  @db.Decimal(10, 2)
  status        String
  label         String
  description   String?
  referenceId   String?
  mlOrderId     BigInt?
  mlPackId      BigInt?
  packId        String?
  quantity      Int      @default(1)
  dateCreated   DateTime
  syncedAt      DateTime @default(now())

  pack Pack? @relation(fields: [packId], references: [id])

  @@index([dateCreated])
  @@index([label])
  @@index([packId])
}

model ProductGroup {
  id        String @id @default(cuid())
  name      String @unique
  color     String @default("#6b7280")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    ProductGroupItem[]
  expenses Expense[]
}

model ProductGroupItem {
  id             String @id @default(cuid())
  productGroupId String
  productId      String

  productGroup ProductGroup @relation(fields: [productGroupId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productGroupId, productId])
}

model PackCost {
  id       String  @id @default(cuid())
  packId   String
  category String
  amount   Decimal @db.Decimal(10, 2)
  notes    String?

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([packId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
